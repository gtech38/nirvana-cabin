# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit it.

# ─────────────────────────────────────────────────────────────────────────────
# OwnerRez booking widgets (/book page)
#
# Where to find these values:
#   • Log in to OwnerRez → Hosted Website → Widgets
#   • Each widget has a GUID shown in its embed snippet
#   • Property GUID is shown in the embed snippet's data-propertyid attribute
#   • Numeric property ID is in Properties → [Nirvana] → Settings
# ─────────────────────────────────────────────────────────────────────────────

VITE_OWNERREZ_PROPERTY_GUID=
VITE_OWNERREZ_CALENDAR_WIDGET_ID=
VITE_OWNERREZ_BOOKING_WIDGET_ID=

# Used only for the hosted-booking fallback link shown when the widgets are
# unavailable. Numeric (not GUID).
VITE_OWNERREZ_PROPERTY_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Contact
# ─────────────────────────────────────────────────────────────────────────────

VITE_CONTACT_EMAIL=
